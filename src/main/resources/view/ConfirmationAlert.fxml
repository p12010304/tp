<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.Scene?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.stage.Stage?>

<fx:root resizable="false" title="Alert" type="javafx.stage.Stage" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
    <icons>
        <Image url="@/images/exclamation_mark_icon.png" />
    </icons>
    <scene>
        <Scene>
            <stylesheets>
                <URL value="@AlertWindow.css" />
            </stylesheets>

            <VBox fx:id="alertMessageContainer">
                <children>
                      <Label fx:id="alertLabel" text="Label" />
                    <HBox alignment="BOTTOM_RIGHT" spacing="5.0">
                        <children>
                            <Button fx:id="yesButton" mnemonicParsing="false" onAction="#yesSelected" prefWidth="50.0" text="Yes">
                                <HBox.margin>
                                    <Insets left="5.0" />
                                </HBox.margin>
                            </Button>
                            <Button fx:id="noButton" layoutX="52.0" layoutY="15.0" mnemonicParsing="false" onAction="#noSelected" prefWidth="50.0" text="No" />
                        </children>
                        <opaqueInsets>
                            <Insets bottom="10.0" left="5.0" right="10.0" top="5.0" />
                        </opaqueInsets>
                  <padding>
                     <Insets left="5.0" right="5.0" top="5.0" />
                  </padding>
                    </HBox>
                </children>
            <padding>
               <Insets bottom="10.0" left="5.0" right="10.0" top="5.0" />
            </padding>
            </VBox>
        </Scene>
    </scene>
</fx:root>
