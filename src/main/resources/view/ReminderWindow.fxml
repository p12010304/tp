<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.Scene?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.stage.Stage?>
<?import javafx.scene.layout.VBox?>

<fx:root resizable="false" title="Alert" type="javafx.stage.Stage" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
  <icons>
    <Image url="@/images/exclamation_mark_icon.png" />
  </icons>
  <scene>
    <Scene>
      <stylesheets>
        <URL value="@ReminderWindow.css" />
      </stylesheets>

      <VBox  alignment="TOP_LEFT" fx:id="reminderMessageContainer">
        <children>
          <Label fx:id="reminderMessage" text="Label">
          </Label>
        </children>
        <opaqueInsets>
          <Insets bottom="10.0" left="5.0" right="10.0" top="5.0" />
        </opaqueInsets>
        <padding>
          <Insets bottom="10.0" left="5.0" right="10.0" top="5.0" />
        </padding>
      </VBox>
    </Scene>
  </scene>
</fx:root>
